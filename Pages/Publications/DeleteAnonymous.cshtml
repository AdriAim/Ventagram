@page
@model Ventagram.Pages.Publications.DeleteAnonymousModel
@{
    ViewData["Title"] = "Dar de baja";
}

<section class="form-shell narrow">
    <div class="section-heading">
        <span class="eyebrow">Publicación anónima</span>
        <h1>Dar de baja una publicación</h1>
        <p>Ingresá el ID y la contraseña que se generó al crear el aviso.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner">@Model.StatusMessage</div>
    }

    <form method="post" class="stack-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <label><span>ID publicación</span><input asp-for="Input.PublicationId" type="number" /></label>
            <label><span>Contraseña</span><input asp-for="Input.Password" /></label>
        </div>
        <div class="hero-actions">
            <button type="submit" class="primary-pill">Dar de baja</button>
            <a class="ghost-pill" asp-page="/Index">Volver</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
