@page
@model Ventagram.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Ingresar";
}

<section class="form-shell narrow">
    <div class="section-heading">
        <span class="eyebrow">Acceso</span>
        <h1>Ingresá a tu cuenta</h1>
        <p>Podés entrar con email y contraseña o con Google si cargaste las credenciales.</p>
    </div>

    <form method="post" class="stack-form">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <label><span>Email</span><input asp-for="Input.Email" /></label>
            <label><span>Contraseña</span><input asp-for="Input.Password" type="password" /></label>
        </div>
        <div class="hero-actions">
            <button type="submit" class="primary-pill">Ingresar</button>
            @if (Model.IsGoogleEnabled)
            {
                <button type="submit" asp-page-handler="Google" class="ghost-pill">Continuar con Google</button>
            }
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
